{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug FastAPI Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--reload",
        "--port",
        "8001"
      ],
      "cwd": "${workspaceFolder:Backend (FastAPI)}",
      "jinja": true,
      "python": "${workspaceFolder:Backend (FastAPI)}/venv/Scripts/python.exe"
    },
    {
      "name": "Debug Local Worker",
      "type": "debugpy",
      "request": "launch",
      "program": "local_consumer.py",
      "cwd": "${workspaceFolder:Worker (Python)}",
      "python": "${workspaceFolder:Worker (Python)}/venv/Scripts/python.exe"
    },
    {
      "name": "Debug React Frontend (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder:Frontend (React)}/src"
    }
  ],
  "compounds": [
    {
      "name": "Debug Backend + Worker",
      "configurations": [
        "Debug FastAPI Backend",
        "Debug Local Worker"
      ]
    },
    {
      "name": "Debug Full Stack (Backend + Worker + Frontend)",
      "configurations": [
        "Debug FastAPI Backend",
        "Debug Local Worker",
        "Debug React Frontend (Chrome)"
      ]
    }
  ]
}
